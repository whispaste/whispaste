---
interface Props {
  variant?: "landing" | "subpage";
}
const { variant = "landing" } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 bg-brand-darker/80 backdrop-blur-xl border-b border-white/5"
>
  <div
    class={`mx-auto px-6 h-14 flex items-center justify-between ${variant === "subpage" ? "max-w-4xl" : "max-w-6xl"}`}
  >
    <a
      href={variant === "subpage" ? "/whispaste/" : "#"}
      class="flex items-center gap-2 text-white font-semibold tracking-tight"
    >
      <img
        id="navLogo"
        src="/whispaste/app-icon-dark.png"
        alt="WhisPaste"
        class="w-8 h-8"
      />
      <span class="text-lg font-semibold tracking-tight">WhisPaste</span>
    </a>
    {
      variant === "landing" ? (
        <div class="hidden sm:flex items-center gap-6 text-sm text-gray-400">
          <a
            href="#features"
            class="hover:text-white transition-colors"
            data-i18n="nav.features"
          >
            Features
          </a>
          <a
            href="#how-it-works"
            class="hover:text-white transition-colors"
            data-i18n="nav.howitworks"
          >
            How It Works
          </a>
          <button
            id="langToggle"
            data-testid="lang-toggle"
            onclick="toggleLang()"
            class="text-gray-400 hover:text-white transition-colors text-sm font-medium"
          >
            DE
          </button>
          <button
            id="themeToggle"
            onclick="toggleTheme()"
            class="text-gray-400 hover:text-white transition-colors"
            title="Toggle theme"
          >
            <svg
              id="themeIcon"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
          <a
            href="https://github.com/whispaste/whispaste"
            target="_blank"
            rel="noopener"
            class="hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
          </a>
        </div>
      ) : (
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <a href="/whispaste/" class="hover:text-white transition-colors">
            &larr; Back
          </a>
          <button
            id="langToggle"
            data-testid="lang-toggle"
            onclick="toggleLang()"
            class="text-gray-400 hover:text-white transition-colors font-medium"
          >
            DE
          </button>
          <button
            id="themeToggle"
            onclick="toggleTheme()"
            class="text-gray-400 hover:text-white transition-colors"
            title="Toggle theme"
          >
            <svg
              id="themeIcon"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      )
    }
  </div>
</nav>
