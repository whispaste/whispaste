                    </svg>
                  </div>
                  <div class="overlay-pill">
                    <img src="/whispaste/app-icon-dark.png" alt="" class="overlay-icon" />
                    <div class="overlay-content">
                      <div class="overlay-rec-dot"></div>
                      <div class="overlay-text-group">
                        <span class="overlay-text-main" data-i18n="carousel.recording">Recording</span>
                        <span class="overlay-text-timer" id="overlay-timer">0:00</span>
