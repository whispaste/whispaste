</section>

<style>
  /* Animations */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(40px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out both;
  }
  .animate-fade-in-delay {
    animation: fade-in 0.8s ease-out 0.3s both;
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out 0.5s both;
  }
  .hero-glow {
    animation: glow-pulse 6s ease-in-out infinite;
  }
  .hero-gradient {
    background: linear-gradient(135deg, #22D3EE 0%, #0E7490 50%, #22D3EE 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: gradient-shift 5s ease-in-out infinite;
  }
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Carousel keys group */
  .carousel-keys-group {
    display: flex;
    align-items: end;
    gap: 6px;
    transform: rotate(-6deg);
  }
  .carousel-keys-group .carousel-key--action {
    margin-left: 10px;
  }

  /* Cursor pointer animation */
  .carousel-cursor {
    position: absolute;
    right: -24px;
    top: -8px;
    pointer-events: none;
    animation: cursor-press 3s ease-in-out infinite;
    filter: drop-shadow(0 3px 6px rgba(0,0,0,0.35));
    transform-origin: 60% 30%;
  }
  @keyframes cursor-press {
    0%, 6% { opacity: 0; transform: rotate(-15deg) translate(28px, 40px); }
    20% { opacity: 0.8; transform: rotate(-15deg) translate(0, 4px); }
    26%, 50% { opacity: 0.8; transform: rotate(-15deg) translate(0, 10px); }
    58% { opacity: 0; transform: rotate(-15deg) translate(0, 10px); }
    100% { opacity: 0; transform: rotate(-15deg) translate(28px, 40px); }
  }

  /* Carousel key animation */
  .carousel-key {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%);
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .carousel-key--modifier {
    animation: key-press-mod 3s ease-in-out infinite;
  }
  .carousel-key--action {
    animation: key-press-act 3s ease-in-out infinite;
  }
  @keyframes key-press-mod {
    0%, 10% { transform: translateY(0); box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1); }
    14%, 52% { transform: translateY(4px); box-shadow: 0 0px 0 rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1); }
    58%, 100% { transform: translateY(0); box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1); }
  }
  @keyframes key-press-act {
    0%, 22% { transform: translateY(0); box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1); }
    26%, 52% { transform: translateY(4px); box-shadow: 0 0px 0 rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1); }
    58%, 100% { transform: translateY(0); box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1); }
  }

  /* Overlay pill (Scene 2) */
  .overlay-pill {
    position: relative;
    width: 490px;
    height: 64px;
    border-radius: 32px;
    background: rgba(10, 26, 41, 0.75);
    border: 1.5px solid rgba(0, 102, 184, 0.6);
    box-shadow: 3px 3px 8px rgba(0,0,0,0.25);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    display: flex;
    align-items: center;
    font-family: 'Segoe UI', system-ui, sans-serif;
    transform: scale(0.85);
    transform-origin: center;
  }
  @media (min-width: 640px) {
    .overlay-pill { transform: scale(1); }
  }
  .overlay-icon {
    width: 36px;
    height: 36px;
    margin-left: 14px;
    border-radius: 4px;
  }
  .overlay-content {
    margin-left: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .overlay-text-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .overlay-rec-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #FF3C3C;
    animation: rec-pulse 1.2s ease-in-out infinite;
  }
  @keyframes rec-pulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
  .overlay-text-main {
    font-size: 15px;
    font-weight: 600;
    color: #FFFFFF;
    line-height: 1;
  }
  .overlay-text-timer {
    font-size: 11px;
    font-weight: 400;
    color: #90A0B0;
    line-height: 1;
  }
  .overlay-waveform {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-left: auto;
    margin-right: 8px;
    height: 48px;
    flex-shrink: 0;
    min-width: 137px;
  }
  .overlay-buttons {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-right: 12px;
  }
  .overlay-btn-pause, .overlay-btn-confirm {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .overlay-btn-pause svg, .overlay-btn-confirm svg {
    width: 34px;
    height: 34px;
  }
  .overlay-btn-pause { background: #0E7490; }
  .overlay-btn-confirm { background: #22D3EE; }

  /* Speaking head + microphone icon (Scene 2) */
  .speaking-head {
    color: rgba(255, 255, 255, 0.5);
  }
  .microphone-icon {
    color: rgba(255, 255, 255, 0.4);
    animation: mic-glow 1.8s ease-in-out infinite;
  }
  @keyframes mic-glow {
    0%, 100% { color: rgba(255, 255, 255, 0.4); }
    50% { color: #22D3EE; }
  }
  .speaking-head-icon .sound-arc {
    opacity: 0;
    stroke: #22D3EE;
  }
  .sound-arc.arc-1 { animation: sound-pulse 1.8s ease-in-out infinite; }
  .sound-arc.arc-2 { animation: sound-pulse 1.8s ease-in-out 0.3s infinite; }
  @keyframes sound-pulse {
    0%, 100% { opacity: 0; }
    30%, 70% { opacity: 0.7; }
  }

  /* Reduced motion for hero animations */
  @media (prefers-reduced-motion: reduce) {
    .hero-glow,
    .hero-gradient,
    .carousel-key,
    .carousel-cursor,
    .overlay-rec-dot,
    .sound-arc,
    .microphone-icon,
    .animate-fade-in,
    .animate-fade-in-delay,
    .animate-fade-in-up {
      animation: none !important;
    }
    #carousel-track {
      transition: none !important;
    }
  }
</style>

<!-- Global styles for dynamically-created elements -->
<style is:global>
  .overlay-wave-bar {
    width: 4px;
    border-radius: 2px;
    min-height: 2px;
    flex-shrink: 0;
  }

  /* Typing cursor — :global because JS recreates it */
  .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1.1em;
    background: #22D3EE;
    margin-left: 1px;
    animation: cursor-blink 0.8s step-end infinite;
    vertical-align: text-bottom;
  }
  .carousel-heart {
    color: #EF4444;
  }
  @keyframes cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Light theme: carousel fixes */
  html.light .carousel-key {
    background: linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.08) 100%) !important;
    border-color: rgba(0,0,0,0.15) !important;
    box-shadow: 0 4px 0 rgba(0,0,0,0.12), 0 6px 12px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.6) !important;
  }
  html.light .carousel-key svg { color: #334155 !important; }
  html.light .carousel-cursor path { fill: #334155 !important; fill-opacity: 0.8 !important; stroke: rgba(0,0,0,0.15) !important; }
  html.light .speaking-head { color: rgba(0,0,0,0.5) !important; }
  html.light .microphone-icon { color: rgba(0,0,0,0.4) !important; }
  html.light .carousel-dot { background: rgba(0,0,0,0.15) !important; }
  html.light .carousel-dot.bg-brand-cyan { background: #0891B2 !important; }
  html.light #typed-text { color: #1E293B !important; }
  html.light .microphone-icon { animation-name: mic-glow-light !important; }
  @keyframes mic-glow-light {
    0%, 100% { color: rgba(0,0,0,0.4); }
    50% { color: #0891B2; }
  }
  html.light .overlay-pill {
    box-shadow: 3px 3px 16px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,102,184,0.3) !important;
  }
  html.light .typing-cursor { background: #0891B2 !important; }

  /* Reduced motion for dynamic elements */
  @media (prefers-reduced-motion: reduce) {
    .overlay-wave-bar,
    .typing-cursor {
      animation: none !important;
    }
  }
</style>

<script>
  // Carousel
  const track = document.getElementById('carousel-track');
  const dots = document.querySelectorAll('.carousel-dot');
  let currentSlide = 0;
  const totalSlides = 3;
  const SLIDE_DURATIONS = [5000, 5000, 8000];
  let carouselTimer: ReturnType<typeof setTimeout>;
  let reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let overlayTimerInterval: ReturnType<typeof setInterval>;

  function startOverlayTimer() {
    clearInterval(overlayTimerInterval);
    const timerEl = document.getElementById('overlay-timer');
    if (!timerEl) return;
    let seconds = 0;
    timerEl.textContent = '0:00';
    overlayTimerInterval = setInterval(() => {
      seconds++;
      timerEl.textContent = Math.floor(seconds / 60) + ':' + String(seconds % 60).padStart(2, '0');
    }, 1000);
  }

  function stopOverlayTimer() {
    clearInterval(overlayTimerInterval);
  }

  function goToSlide(n: number) {
    currentSlide = n;
    if (track) track.style.transform = `translateX(-${n * 100}%)`;
    dots.forEach((dot, i) => {
      if (i === n) {
        dot.classList.remove('bg-white/20');
        dot.classList.add('bg-brand-cyan');
        (dot as HTMLElement).style.width = '16px';
      } else {
        dot.classList.add('bg-white/20');
        dot.classList.remove('bg-brand-cyan');
        (dot as HTMLElement).style.width = '8px';
      }
    });
    if (n === 1) startOverlayTimer(); else stopOverlayTimer();
    if (n === 2) startTyping();
  }

  function scheduleNext() {
    clearTimeout(carouselTimer);
    if (reducedMotion) return;
    carouselTimer = setTimeout(nextSlide, SLIDE_DURATIONS[currentSlide]);
  }

  function nextSlide() {
    goToSlide((currentSlide + 1) % totalSlides);
    scheduleNext();
  }

  function startCarousel() {
    scheduleNext();
  }

  function stopCarousel() {
    clearTimeout(carouselTimer);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      stopCarousel();
      goToSlide(parseInt((dot as HTMLElement).dataset.slide!));
      scheduleNext();
    });
  });

  // Waveform animation
  const waveformEl = document.getElementById('overlay-waveform');
  const waveBars: { el: HTMLElement; phase: number; speed: number; amp: number }[] = [];
  if (waveformEl) {
    for (let i = 0; i < 20; i++) {
      const bar = document.createElement('div');
      bar.className = 'overlay-wave-bar';
      bar.style.height = '2px';
      bar.style.background = '#186688';
      waveformEl.appendChild(bar);
      waveBars.push({ el: bar, phase: Math.random() * Math.PI * 2, speed: 1.5 + Math.random() * 2.5, amp: 0.3 + Math.random() * 0.7 });
    }
    let waveRaf: number;
    function animateWave(t: number) {
      for (let i = 0; i < waveBars.length; i++) {
        const b = waveBars[i];
        const val = (Math.sin(t * 0.003 * b.speed + b.phase) + 1) / 2 * b.amp;
        const h = Math.max(2, Math.round(val * 36));
        b.el.style.height = h + 'px';
        b.el.style.background = h > 6 ? '#22D3EE' : '#186688';
      }
      waveRaf = requestAnimationFrame(animateWave);
    }
    waveRaf = requestAnimationFrame(animateWave);
  }

  // Typing animation for scene 3
  const typedEl = document.getElementById('typed-text');
  let typingTimeout: ReturnType<typeof setTimeout>;

  function getTypingSegments() {
    const lang = (window as any).currentLang || 'en';
    if (lang === 'de') {
      return [
        { text: 'Hey, diesen Text habe ich\ngerade eben eingesprochen\nund ' },
        { text: 'WhisPaste', cls: 'text-brand-cyan font-semibold' },
        { text: ' hat ihn direkt\nhier eingefügt. ' },
        { text: '❤️', cls: 'carousel-heart' },
        { text: ' 😊' }
      ];
    }
    return [
      { text: 'Hey, I just spoke this text\nand ' },
      { text: 'WhisPaste', cls: 'text-brand-cyan font-semibold' },
      { text: ' pasted it right\nhere automatically. ' },
      { text: '❤️', cls: 'carousel-heart' },
      { text: ' 😊' }
    ];
  }

  function startTyping() {
    if (!typedEl) return;
    clearTimeout(typingTimeout);
    const segments = getTypingSegments();
    typedEl.innerHTML = '<span class="typing-cursor"></span>';
    let segIdx = 0, charIdx = 0;
    let currentSpan: any = null;

    function typeChar() {
      if (segIdx >= segments.length || currentSlide !== 2) return;
      const seg = segments[segIdx];
      const cursor = typedEl!.querySelector('.typing-cursor');
      if (!cursor) return;

      if (!currentSpan || currentSpan._segIdx !== segIdx) {
        if (seg.cls) {
          currentSpan = document.createElement('span');
          currentSpan.className = seg.cls;
          currentSpan._segIdx = segIdx;
          typedEl!.insertBefore(currentSpan, cursor);
        } else {
          currentSpan = { _segIdx: segIdx, _isText: true };
        }
      }

      const ch = seg.text[charIdx];
      if (currentSpan._isText) {
        typedEl!.insertBefore(document.createTextNode(ch), cursor);
      } else {
        currentSpan.appendChild(document.createTextNode(ch));
      }

      charIdx++;
      if (charIdx >= seg.text.length) {
        segIdx++;
        charIdx = 0;
        currentSpan = null;
      }

      if (segIdx < segments.length) {
        typingTimeout = setTimeout(typeChar, 40 + Math.random() * 40);
      }
    }
    typingTimeout = setTimeout(typeChar, 400);
  }

  startCarousel();
  goToSlide(0);
</script>
