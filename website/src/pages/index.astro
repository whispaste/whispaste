---
import Layout from "../layouts/Layout.astro";
---

<Layout title="WhisPaste — Voice to text, pasted anywhere">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-brand-darker/80 backdrop-blur-xl border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2 text-white font-semibold tracking-tight">
        <img id="navLogo" src="/whispaste/app-icon-dark.png" alt="WhisPaste" class="w-8 h-8" />
        <span class="text-lg font-semibold tracking-tight">WhisPaste</span>
      </a>
      <div class="hidden sm:flex items-center gap-6 text-sm text-gray-400">
        <a href="#features" class="hover:text-white transition-colors" data-i18n="nav.features">Features</a>
        <a href="#how-it-works" class="hover:text-white transition-colors" data-i18n="nav.howitworks">How It Works</a>
        <button id="langToggle" onclick="toggleLang()" class="text-gray-400 hover:text-white transition-colors text-sm font-medium">DE</button>
        <button id="themeToggle" onclick="toggleTheme()" class="text-gray-400 hover:text-white transition-colors" title="Toggle theme">
          <svg id="themeIcon" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="https://github.com/whispaste/whispaste" target="_blank" rel="noopener" class="hover:text-white transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden pt-14">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_center,_rgba(34,211,238,0.12)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(14,116,144,0.08)_0%,_transparent_50%)]"></div>
    <div class="hero-glow absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-brand-cyan/[0.07] rounded-full blur-[120px]"></div>

    <!-- Floating grid lines for depth -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <div class="animate-fade-in">
        <div class="mb-8 mt-4">
          <img id="heroLogo" src="/whispaste/app-icon-dark.png" alt="WhisPaste" class="w-24 h-24 mx-auto rounded-2xl" />
        </div>
        <h1 class="text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-[1.05]">
          <span data-i18n="hero.title1">Voice to text,</span><br>
          <span class="hero-gradient" data-i18n="hero.title2">pasted anywhere.</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-400 max-w-xl mx-auto leading-relaxed" data-i18n="hero.desc">
          A lightweight desktop tool that transcribes your speech with OpenAI Whisper and pastes the result into any focused input field.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-delay">
        <a href="https://github.com/whispaste/whispaste/releases/latest" class="group relative inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-brand-cyan text-brand-darker font-semibold rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] shadow-[0_0_30px_rgba(34,211,238,0.3)] hover:shadow-[0_0_40px_rgba(34,211,238,0.5)]">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          <span data-i18n="hero.download">Download for Windows</span>
        </a>
        <a href="https://github.com/whispaste/whispaste" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white/[0.04] text-white font-semibold rounded-xl border border-white/10 hover:bg-white/[0.08] hover:border-white/20 transition-all hover:scale-[1.02] active:scale-[0.98] backdrop-blur-sm">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          <span data-i18n="hero.github">View on GitHub</span>
        </a>
      </div>
      <p class="mt-6 text-sm text-gray-500 animate-fade-in-delay" data-i18n="hero.meta">Portable .exe · No installer · ~8 MB</p>

      <!-- Carousel -->
      <div class="mt-16 animate-fade-in-up">
        <div class="relative mx-auto max-w-2xl">
          <!-- Carousel viewport -->
          <div class="overflow-hidden">
            <div id="carousel-track" class="flex transition-transform duration-700 ease-in-out" style="transform: translateX(0%);">
              <!-- Scene 1: Hotkey Press -->
              <div class="w-full shrink-0">
                <div class="p-8 sm:p-12 flex flex-col items-center justify-center min-h-[220px]">
                  <div class="carousel-keys-group mb-6">
                    <div class="carousel-key" style="--press-delay: 0s;">
                      <svg class="w-5 h-5 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>
                    </div>
                    <div class="carousel-key" style="--press-delay: 0.15s;">
                      <svg class="w-5 h-5 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/></svg>
                    </div>
                    <div class="carousel-key carousel-key--action" style="--press-delay: 0.3s;">
                      <svg class="w-5 h-5 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                    </div>
                  </div>
                  <span class="text-sm text-gray-400" data-i18n="carousel.hotkey">Your Hotkey</span>
                </div>
              </div>
                <!-- Scene 2: Recording Overlay -->
                <div class="w-full shrink-0">
                  <div class="p-8 sm:p-12 flex items-center justify-center min-h-[220px]">
                    <div class="overlay-pill">
                      <img src="/whispaste/app-icon-dark.png" alt="" class="overlay-icon" />
                      <div class="overlay-content">
                        <div class="overlay-status">
                          <div class="overlay-rec-dot"></div>
                          <span class="overlay-text-main" data-i18n="carousel.recording">Recording</span>
                        </div>
                        <span class="overlay-text-timer" id="overlay-timer">0:00</span>
                      </div>
                      <div class="overlay-waveform" id="overlay-waveform"></div>
                      <div class="overlay-buttons">
                        <div class="overlay-btn-pause">
                          <svg viewBox="0 0 34 34" width="34" height="34" fill="white"><rect x="11" y="10" width="4" height="14" rx="1"/><rect x="19" y="10" width="4" height="14" rx="1"/></svg>
                        </div>
                        <div class="overlay-btn-confirm">
                          <svg viewBox="0 0 34 34" width="34" height="34" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="10 17 15 23 25 11"/></svg>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Scene 3: Text Insertion -->
                <div class="w-full shrink-0">
                  <div class="p-6 min-h-[220px]">
                    <div class="flex items-center gap-2 px-4 py-2.5 bg-brand-card/60 border-b border-white/5 rounded-t-lg">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
                      </div>
                      <span class="ml-2 text-xs text-gray-500 font-mono" data-i18n="carousel.editor_title">Text Editor</span>
                    </div>
                    <div class="bg-brand-darker/80 border border-white/5 border-t-0 rounded-b-lg p-4 min-h-[140px]">
                      <div class="flex items-start gap-3">
                        <div class="text-xs text-gray-600 font-mono select-none leading-relaxed pt-0.5">1<br>2<br>3</div>
                        <div id="typed-text" class="text-sm text-white/90 font-mono leading-relaxed whitespace-pre-wrap">
                          <span class="typing-cursor"></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <!-- Dot indicators -->
          <div class="flex justify-center gap-2 pt-4">
            <button class="carousel-dot active w-2 h-2 rounded-full bg-brand-cyan transition-all" data-slide="0" style="width:16px;"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 hover:bg-white/40 transition-all" data-slide="1"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 hover:bg-white/40 transition-all" data-slide="2"></button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gradient transition -->
  <div class="h-24 bg-gradient-to-b from-transparent via-brand-cyan/[0.03] to-transparent -mt-12 -mb-12 relative z-0"></div>

  <!-- Features -->
  <section id="features" class="py-24 sm:py-32 relative scroll-mt-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(14,116,144,0.05)_0%,_transparent_70%)]"></div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 scroll-reveal">
        <p class="text-brand-cyan text-sm font-semibold tracking-wider uppercase mb-3" data-i18n="features.label">Features</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white" data-i18n="features.title">Everything you need</h2>
        <p class="mt-4 text-gray-400 text-lg max-w-2xl mx-auto" data-i18n="features.desc">Powerful features in a lightweight package. No bloat, no subscriptions — just your API key and you're ready.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m9 8 3 3-3 3"/><path d="M14 16h4"/></svg>`, title: "Global Hotkey", desc: "Press your hotkey from anywhere — push-to-talk or toggle mode. Fully configurable." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>`, title: "Auto-Paste", desc: "Transcribed text lands at your cursor automatically. Clipboard always updated." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>`, title: "Smart Mode", desc: "AI post-processing with GPT: clean up, format, translate, or apply custom prompts." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>`, title: "Premium Overlay", desc: "Anti-aliased waveform, timer, and controls — always on top while recording." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`, title: "Dashboard", desc: "Search, tag, pin, and organize all your transcriptions in one place." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`, title: "Privacy First", desc: "Direct API connection, no telemetry, no tracking. BYOK — bring your own key." },
        ].map(({ icon, title, desc }) => (
          <div class="feature-card group p-6 rounded-2xl border border-white/[0.06] hover:border-brand-cyan/30 transition-all duration-300 scroll-reveal">
            <div class="w-10 h-10 rounded-xl bg-brand-cyan/10 text-brand-cyan flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-brand-cyan/15 transition-all duration-300" set:html={icon} />
            <h3 class="text-white font-semibold mb-1.5">{title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-24 sm:py-32 relative scroll-mt-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_rgba(14,116,144,0.08)_0%,_transparent_60%)]"></div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 scroll-reveal">
        <p class="text-brand-cyan text-sm font-semibold tracking-wider uppercase mb-3" data-i18n="howitworks.label">Workflow</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white" data-i18n="howitworks.title">How it works</h2>
        <p class="mt-4 text-gray-400 text-lg" data-i18n="howitworks.desc">Three steps. Zero friction.</p>
      </div>
      <div class="relative">
        <!-- Connecting line (desktop only) -->
        <div class="hidden lg:block absolute top-8 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-brand-cyan/0 via-brand-cyan/30 to-brand-cyan/0"></div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {[
            { step: "1", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m9 8 3 3-3 3"/><path d="M14 16h4"/></svg>`, title: "Press Hotkey", desc: "Hit your hotkey from any app" },
            { step: "2", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`, title: "Speak & Transcribe", desc: "Whisper converts your speech to text" },
            { step: "3", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>`, title: "Auto-Paste", desc: "Text appears at your cursor" },
          ].map(({ step, icon, title, desc }) => (
            <div class="text-center scroll-reveal">
              <div class="relative inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-card/80 border border-brand-border/60 mb-4 text-brand-cyan shadow-lg shadow-brand-cyan/[0.05]" set:html={icon}>
              </div>
              <div class="text-xs font-mono text-brand-cyan tracking-wider mb-1.5">Step {step}</div>
              <h3 class="text-white font-semibold mb-1">{title}</h3>
              <p class="text-gray-400 text-sm">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="py-24 sm:py-32 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(14,116,144,0.06)_0%,_transparent_60%)]"></div>
    <div class="relative max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 scroll-reveal">
        <p class="text-brand-cyan text-sm font-semibold tracking-wider uppercase mb-3" data-i18n="privacy.label">Security</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white" data-i18n="privacy.title">Privacy first</h2>
        <p class="mt-4 text-gray-400 text-lg" data-i18n="privacy.desc">Your data stays yours. Always.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 scroll-reveal">
        {[
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, title: "API key stays local", desc: "Stored only in your user profile directory, never transmitted." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`, title: "Direct API connection", desc: "Audio is sent directly from your device to OpenAI's Whisper API — WhisPaste never stores or processes your recordings. See OpenAI's privacy policy for their data handling." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M21 21v-5h-5"/></svg>`, title: "Secure updates", desc: "SHA256 checksums verified before applying. HTTPS only." },
          { icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`, title: "No telemetry", desc: "Zero analytics, tracking, or phone-home. Fully open source." },
        ].map(({ icon, title, desc }) => (
          <div class="flex gap-4 p-5 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:border-white/[0.1] transition-colors">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-brand-cyan/10 text-brand-cyan flex items-center justify-center" set:html={icon} />
            <div>
              <h3 class="text-white font-semibold mb-0.5">{title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="py-24 sm:py-32 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(14,116,144,0.05)_0%,_transparent_50%)]"></div>
    <div class="relative max-w-2xl mx-auto px-6 text-center scroll-reveal">
      <div class="p-10 rounded-3xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm">
        <h2 class="text-2xl sm:text-3xl font-bold text-white" data-i18n="support.title">Support the project</h2>
        <p class="mt-3 text-gray-400" data-i18n="support.desc">WhisPaste is free and open source. If you find it useful, consider supporting development.</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://github.com/sponsors/silvio-l" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/[0.04] text-white font-medium rounded-xl border border-white/10 hover:bg-pink-500/10 hover:border-pink-500/30 hover:text-pink-400 transition-all text-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            <span data-i18n="support.sponsor">Sponsor on GitHub</span>
          </a>
          <a href="https://ko-fi.com/silviol" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/[0.04] text-white font-medium rounded-xl border border-white/10 hover:bg-orange-500/10 hover:border-orange-500/30 hover:text-orange-400 transition-all text-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
            <span data-i18n="support.coffee">Buy a Coffee</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <div class="flex items-center gap-2">
        <img id="footerLogo" src="/whispaste/app-icon-dark.png" alt="" class="w-6 h-6 opacity-60" />
        <span>&copy; 2025 <a href="https://github.com/silvio-l" class="hover:text-white transition-colors">Silvio Lindstedt</a></span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/whispaste/impressum/" class="hover:text-white transition-colors" data-i18n="footer.impressum">Legal Notice</a>
        <a href="/whispaste/datenschutz/" class="hover:text-white transition-colors" data-i18n="footer.privacy">Privacy Policy</a>
        <span data-i18n="footer.license">MIT License</span>
        <a href="https://github.com/whispaste/whispaste" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

  <style>
    /* Animations */
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(40px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes glow-pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }
    .animate-fade-in {
      animation: fade-in 0.8s ease-out both;
    }
    .animate-fade-in-delay {
      animation: fade-in 0.8s ease-out 0.3s both;
    }
    .animate-fade-in-up {
      animation: fade-in-up 1s ease-out 0.5s both;
    }
    .hero-glow {
      animation: glow-pulse 6s ease-in-out infinite;
    }
    .hero-gradient {
      background: linear-gradient(135deg, #22D3EE 0%, #0E7490 50%, #22D3EE 100%);
      background-size: 200% 200%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      animation: gradient-shift 5s ease-in-out infinite;
    }
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .scroll-reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    }
    .scroll-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Glassmorphism feature cards */
    .feature-card {
      background: linear-gradient(135deg, rgba(37, 40, 48, 0.5) 0%, rgba(30, 32, 38, 0.3) 100%);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .feature-card:hover {
      background: linear-gradient(135deg, rgba(37, 40, 48, 0.7) 0%, rgba(34, 211, 238, 0.03) 100%);
      box-shadow: 0 0 30px rgba(34, 211, 238, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    /* Carousel keys group — slightly tilted, modifier keys closer */
    .carousel-keys-group {
      display: flex;
      align-items: end;
      gap: 6px;
      transform: rotate(-6deg);
    }
    .carousel-keys-group .carousel-key--action {
      margin-left: 10px;
    }

    /* Carousel key animation */
    .carousel-key {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
      animation: key-press 2s ease-in-out var(--press-delay) infinite;
      transition: transform 0.1s, box-shadow 0.1s;
    }
    @keyframes key-press {
      0%, 30%, 100% { transform: translateY(0); box-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 6px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1); }
      15% { transform: translateY(4px); box-shadow: 0 0px 0 rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1); }
    }

    /* Overlay pill (Scene 2) */
    .overlay-pill {
      position: relative;
      width: 490px;
      height: 64px;
      border-radius: 32px;
      background: #0A1A29;
      border: 1.5px solid #0066B8;
      box-shadow: 3px 3px 8px rgba(0,0,0,0.25);
      display: flex;
      align-items: center;
      font-family: 'Segoe UI', system-ui, sans-serif;
      transform: scale(0.85);
      transform-origin: center;
    }
    @media (min-width: 640px) {
      .overlay-pill { transform: scale(1); }
    }
    .overlay-icon {
      width: 36px;
      height: 36px;
      margin-left: 14px;
      border-radius: 4px;
    }
    .overlay-content {
      margin-left: 12px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .overlay-status {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .overlay-rec-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #FF3C3C;
      animation: rec-pulse 1.2s ease-in-out infinite;
    }
    @keyframes rec-pulse {
      0%, 100% { opacity: 0.7; }
      50% { opacity: 1; }
    }
    .overlay-text-main {
      font-size: 15px;
      font-weight: 600;
      color: #FFFFFF;
      line-height: 1;
    }
    .overlay-text-timer {
      font-size: 11px;
      font-weight: 400;
      color: #90A0B0;
      line-height: 1;
    }
    .overlay-waveform {
      display: flex;
      align-items: center;
      gap: 3px;
      margin-left: auto;
      margin-right: 8px;
      height: 48px;
    }
    .overlay-wave-bar {
      width: 4px;
      border-radius: 2px;
      background: #22D3EE;
      height: 36px;
      transform-origin: center;
      transform: scaleY(var(--wave-scale-min, 0.06));
      animation: wave-bar-anim var(--wave-dur, 0.8s) ease-in-out var(--wave-delay, 0s) infinite;
    }
    @keyframes wave-bar-anim {
      0%, 100% { transform: scaleY(var(--wave-scale-min, 0.06)); opacity: 0.5; }
      50% { transform: scaleY(var(--wave-scale-max, 0.8)); opacity: 1; }
    }
    .overlay-buttons {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-right: 12px;
    }
    .overlay-btn-pause, .overlay-btn-confirm {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .overlay-btn-pause svg, .overlay-btn-confirm svg {
      width: 34px;
      height: 34px;
    }
    .overlay-btn-pause { background: #0E7490; }
    .overlay-btn-confirm { background: #22D3EE; }

    /* Typing cursor (Scene 3) */
    .typing-cursor {
      display: inline-block;
      width: 2px;
      height: 1.1em;
      background: #22D3EE;
      margin-left: 1px;
      animation: cursor-blink 0.8s step-end infinite;
      vertical-align: text-bottom;
    }
    @keyframes cursor-blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

    /* Accessibility: respect reduced-motion preference */
    @media (prefers-reduced-motion: reduce) {
      .hero-glow,
      .hero-gradient,
      .carousel-key,
      .overlay-rec-dot,
      .overlay-wave-bar,
      .typing-cursor,
      .animate-fade-in,
      .animate-fade-in-delay,
      .animate-fade-in-up {
        animation: none !important;
      }
      #carousel-track {
        transition: none !important;
      }
      .scroll-reveal {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
    }
  </style>

  <script>
    // Scroll reveal observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document.querySelectorAll(".scroll-reveal").forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight + 40) {
        el.classList.add("visible");
      }
      observer.observe(el);
    });
    // Scroll fallback for anchor jumps and fast scrolling
    window.addEventListener('scroll', () => {
      requestAnimationFrame(() => {
        document.querySelectorAll('.scroll-reveal:not(.visible)').forEach(el => {
          if (el.getBoundingClientRect().top < window.innerHeight + 40) {
            el.classList.add('visible');
          }
        });
      });
    }, { passive: true });

    // Carousel
    const track = document.getElementById('carousel-track');
    const dots = document.querySelectorAll('.carousel-dot');
    let currentSlide = 0;
    const totalSlides = 3;
    const SLIDE_DURATIONS = [5000, 5000, 8000]; // keys, overlay, typing (longer for full text)
    let carouselTimer;
    let reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let overlayTimerInterval;

    function startOverlayTimer() {
      clearInterval(overlayTimerInterval);
      const timerEl = document.getElementById('overlay-timer');
      if (!timerEl) return;
      let seconds = 0;
      timerEl.textContent = '0:00';
      overlayTimerInterval = setInterval(() => {
        seconds++;
        timerEl.textContent = Math.floor(seconds / 60) + ':' + String(seconds % 60).padStart(2, '0');
      }, 1000);
    }

    function stopOverlayTimer() {
      clearInterval(overlayTimerInterval);
    }

    function goToSlide(n) {
      currentSlide = n;
      if (track) track.style.transform = `translateX(-${n * 100}%)`;
      dots.forEach((dot, i) => {
        if (i === n) {
          dot.classList.remove('bg-white/20');
          dot.classList.add('bg-brand-cyan');
          dot.style.width = '16px';
        } else {
          dot.classList.add('bg-white/20');
          dot.classList.remove('bg-brand-cyan');
          dot.style.width = '8px';
        }
      });
      if (n === 1) startOverlayTimer(); else stopOverlayTimer();
      if (n === 2) startTyping();
    }

    function scheduleNext() {
      clearTimeout(carouselTimer);
      if (reducedMotion) return;
      carouselTimer = setTimeout(nextSlide, SLIDE_DURATIONS[currentSlide]);
    }

    function nextSlide() {
      goToSlide((currentSlide + 1) % totalSlides);
      scheduleNext();
    }

    function startCarousel() {
      scheduleNext();
    }

    function stopCarousel() {
      clearTimeout(carouselTimer);
    }

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        stopCarousel();
        goToSlide(parseInt(dot.dataset.slide));
        scheduleNext();
      });
    });

    // Generate overlay waveform bars
    const waveformEl = document.getElementById('overlay-waveform');
    if (waveformEl) {
      for (let i = 0; i < 20; i++) {
        const bar = document.createElement('div');
        bar.className = 'overlay-wave-bar';
        const scaleMin = 0.05 + Math.random() * 0.08;
        const scaleMax = 0.3 + Math.random() * 0.7;
        bar.style.setProperty('--wave-scale-min', scaleMin.toFixed(2));
        bar.style.setProperty('--wave-scale-max', scaleMax.toFixed(2));
        bar.style.setProperty('--wave-dur', (0.6 + Math.random() * 0.8).toFixed(2) + 's');
        bar.style.setProperty('--wave-delay', (i * 0.05 + Math.random() * 0.1).toFixed(2) + 's');
        waveformEl.appendChild(bar);
      }
    }

    // Typing animation for scene 3
    const typedEl = document.getElementById('typed-text');
    let typingTimeout;

    function getTypingText() {
      return currentLang === 'de'
        ? 'Hallo, das ist ein Beispiel\nfür transkribierte Sprache. 😊\n— erstellt mit WhisPaste'
        : 'Hello, this is an example\nof transcribed speech. 😊\n— created with WhisPaste';
    }

    function startTyping() {
      if (!typedEl) return;
      clearTimeout(typingTimeout);
      const text = getTypingText();
      typedEl.innerHTML = '<span class="typing-cursor"></span>';
      let i = 0;
      function typeChar() {
        if (i < text.length && currentSlide === 2) {
          const cursor = typedEl.querySelector('.typing-cursor');
          if (cursor) {
            const charNode = document.createTextNode(text[i]);
            typedEl.insertBefore(charNode, cursor);
          }
          i++;
          typingTimeout = setTimeout(typeChar, 40 + Math.random() * 40);
        }
      }
      typingTimeout = setTimeout(typeChar, 400);
    }

    startCarousel();
    goToSlide(0);

    // i18n translations
    const i18n = {
      en: {
        'hero.title1': 'Voice to text,',
        'hero.title2': 'pasted anywhere.',
        'hero.desc': 'A lightweight desktop tool that transcribes your speech with OpenAI Whisper and pastes the result into any focused input field.',
        'hero.download': 'Download for Windows',
        'hero.github': 'View on GitHub',
        'hero.meta': 'Portable .exe · No installer · ~8 MB',
        'nav.features': 'Features',
        'nav.howitworks': 'How It Works',
        'features.label': 'Features',
        'features.title': 'Everything you need',
        'features.desc': 'Powerful features in a lightweight package. No bloat, no subscriptions — just your API key and you\'re ready.',
        'howitworks.label': 'Workflow',
        'howitworks.title': 'How it works',
        'howitworks.desc': 'Three steps. Zero friction.',
        'privacy.label': 'Security',
        'privacy.title': 'Privacy first',
        'privacy.desc': 'Your data stays yours. Always.',
        'support.title': 'Support the project',
        'support.desc': 'WhisPaste is free and open source. If you find it useful, consider supporting development.',
        'support.sponsor': 'Sponsor on GitHub',
        'support.coffee': 'Buy a Coffee',
        'footer.impressum': 'Legal Notice',
        'footer.privacy': 'Privacy Policy',
        'footer.license': 'MIT License',
        'carousel.hotkey': 'Your Hotkey',
        'carousel.recording': 'Recording',
        'carousel.editor_title': 'Text Editor'
      },
      de: {
        'hero.title1': 'Voice to Text,',
        'hero.title2': 'Paste anywhere.',
        'hero.desc': 'Ein schlankes Desktop-Tool — transkribiert Sprache mit OpenAI Whisper und fügt das Ergebnis direkt in jedes Eingabefeld ein.',
        'hero.download': 'Download für Windows',
        'hero.github': 'Auf GitHub ansehen',
        'hero.meta': 'Portable .exe · Kein Installer · ~8 MB',
        'nav.features': 'Features',
        'nav.howitworks': 'So funktioniert\'s',
        'features.label': 'Features',
        'features.title': 'Alles, was du brauchst',
        'features.desc': 'Leistungsstarke Funktionen in einem schlanken Paket. Kein Ballast, kein Abo — nur dein API-Schlüssel.',
        'howitworks.label': 'Workflow',
        'howitworks.title': 'So funktioniert\'s',
        'howitworks.desc': 'Drei Schritte. Null Aufwand.',
        'privacy.label': 'Sicherheit',
        'privacy.title': 'Privatsphäre zuerst',
        'privacy.desc': 'Deine Daten bleiben bei dir. Immer.',
        'support.title': 'Projekt unterstützen',
        'support.desc': 'WhisPaste ist kostenlos und Open Source. Wenn es dir nützlich ist, unterstütze gerne die Entwicklung.',
        'support.sponsor': 'Auf GitHub sponsern',
        'support.coffee': 'Einen Kaffee ausgeben',
        'footer.impressum': 'Impressum',
        'footer.privacy': 'Datenschutz',
        'footer.license': 'MIT-Lizenz',
        'carousel.hotkey': 'Dein Hotkey',
        'carousel.recording': 'Aufnahme',
        'carousel.editor_title': 'Texteditor'
      }
    };

    let currentLang = localStorage.getItem('whispaste-lang') || 'en';

    function toggleLang() {
      currentLang = currentLang === 'en' ? 'de' : 'en';
      localStorage.setItem('whispaste-lang', currentLang);
      applyLang();
    }

    function applyLang() {
      document.documentElement.lang = currentLang;
      const btn = document.getElementById('langToggle');
      if (btn) btn.textContent = currentLang === 'en' ? 'DE' : 'EN';
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (i18n[currentLang]?.[key]) {
          el.textContent = i18n[currentLang][key];
        }
      });
    }

    // Theme toggle
    function toggleTheme() {
      const html = document.documentElement;
      const isDark = !html.classList.contains('light');
      if (isDark) {
        html.classList.add('light');
        localStorage.setItem('whispaste-theme', 'light');
      } else {
        html.classList.remove('light');
        localStorage.setItem('whispaste-theme', 'dark');
      }
      updateThemeIcon();
    }

    function updateThemeIcon() {
      const isLight = document.documentElement.classList.contains('light');
      const icon = document.getElementById('themeIcon');
      if (icon) {
        icon.innerHTML = isLight
          ? '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>'
          : '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
      }
      const lightSrc = '/whispaste/app-icon-light.png';
      const darkSrc = '/whispaste/app-icon-dark.png';
      const src = isLight ? lightSrc : darkSrc;
      ['navLogo', 'heroLogo', 'footerLogo'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.src = src;
      });
    }

    // Expose functions globally for onclick handlers
    window.toggleLang = toggleLang;
    window.toggleTheme = toggleTheme;

    // Apply on load
    applyLang();
    updateThemeIcon();
  </script>
</Layout>
