  <style>
    /* Animations */
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(40px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes glow-pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }
    .animate-fade-in {
      animation: fade-in 0.8s ease-out both;
    }
    .animate-fade-in-delay {
      animation: fade-in 0.8s ease-out 0.3s both;
    }
    .animate-fade-in-up {
      animation: fade-in-up 1s ease-out 0.5s both;
    }
    .hero-glow {
      animation: glow-pulse 6s ease-in-out infinite;
    }
    .hero-gradient {
      background: linear-gradient(135deg, #22D3EE 0%, #0E7490 50%, #22D3EE 100%);
      background-size: 200% 200%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      animation: gradient-shift 5s ease-in-out infinite;
    }
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .scroll-reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    }
    .scroll-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Glassmorphism feature cards */
    .feature-card {
      background: linear-gradient(135deg, rgba(37, 40, 48, 0.5) 0%, rgba(30, 32, 38, 0.3) 100%);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .feature-card:hover {
      background: linear-gradient(135deg, rgba(37, 40, 48, 0.7) 0%, rgba(34, 211, 238, 0.03) 100%);
      box-shadow: 0 0 30px rgba(34, 211, 238, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    /* Waveform bar animation */
    .wave-bar {
      background: linear-gradient(to top, #0E7490, #22D3EE);
      border-radius: 1px;
      width: 3px;
      min-height: 3px;
      animation: wave-bounce var(--duration) ease-in-out var(--delay) infinite;
    }
    @keyframes wave-bounce {
      0%, 100% { height: var(--min-h); }
      50% { height: var(--max-h); }
    }

    /* Accessibility: respect reduced-motion preference */
    @media (prefers-reduced-motion: reduce) {
      .hero-glow,
      .hero-gradient,
      .wave-bar,
      .animate-fade-in,
      .animate-fade-in-delay,
      .animate-fade-in-up {
        animation: none !important;
      }
      .scroll-reveal {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
    }
  </style>

  <script>
    // Scroll reveal observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document.querySelectorAll(".scroll-reveal").forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight + 40) {
        el.classList.add("visible");
      }
      observer.observe(el);
    });
    // Scroll fallback for anchor jumps and fast scrolling
    window.addEventListener('scroll', () => {
      requestAnimationFrame(() => {
        document.querySelectorAll('.scroll-reveal:not(.visible)').forEach(el => {
          if (el.getBoundingClientRect().top < window.innerHeight + 40) {
            el.classList.add('visible');
          }
        });
      });
    }, { passive: true });

    // Hero waveform animation
    const waveContainer = document.getElementById("hero-waveform");
    if (waveContainer) {
      const barCount = 48;
      for (let i = 0; i < barCount; i++) {
        const bar = document.createElement("div");
        bar.className = "wave-bar";
        const center = Math.abs(i - barCount / 2) / (barCount / 2);
        const minH = 3 + Math.random() * 2;
        const maxH = 8 + (1 - center) * 22 + Math.random() * 6;
        const duration = 0.6 + Math.random() * 0.8;
        const delay = i * 0.03 + Math.random() * 0.1;
        bar.style.setProperty("--min-h", minH + "px");
        bar.style.setProperty("--max-h", maxH + "px");
        bar.style.setProperty("--duration", duration + "s");
        bar.style.setProperty("--delay", delay + "s");
        waveContainer.appendChild(bar);
      }
    }

    // i18n translations
    const i18n = {
      en: {
        'hero.title1': 'Voice to text,',
        'hero.title2': 'pasted anywhere.',
        'hero.desc': 'A lightweight desktop tool that transcribes your speech with OpenAI Whisper and pastes the result into any focused input field.',
        'hero.download': 'Download for Windows',
        'hero.github': 'View on GitHub',
        'hero.meta': 'Portable .exe · No installer · ~8 MB',
        'nav.features': 'Features',
        'nav.howitworks': 'How It Works',
        'features.label': 'Features',
        'features.title': 'Everything you need',
        'features.desc': 'Powerful features in a lightweight package. No bloat, no subscriptions — just your API key and you\'re ready.',
        'howitworks.label': 'Workflow',
        'howitworks.title': 'How it works',
        'howitworks.desc': 'Four steps. Zero friction.',
        'privacy.label': 'Security',
        'privacy.title': 'Privacy first',
        'privacy.desc': 'Your data stays yours. Always.',
        'support.title': 'Support the project',
        'support.desc': 'WhisPaste is free and open source. If you find it useful, consider supporting development.',
        'support.sponsor': 'Sponsor on GitHub',
        'support.coffee': 'Buy a Coffee',
        'footer.impressum': 'Legal Notice',
        'footer.privacy': 'Privacy Policy',
        'footer.license': 'MIT License'
      },
      de: {
        'hero.title1': 'Voice to Text,',
        'hero.title2': 'Paste anywhere.',
        'hero.desc': 'Ein schlankes Desktop-Tool — transkribiert Sprache mit OpenAI Whisper und fügt das Ergebnis direkt in jedes Eingabefeld ein.',
        'hero.download': 'Download für Windows',
        'hero.github': 'Auf GitHub ansehen',
        'hero.meta': 'Portable .exe · Kein Installer · ~8 MB',
        'nav.features': 'Features',
        'nav.howitworks': 'So funktioniert\'s',
        'features.label': 'Features',
        'features.title': 'Alles, was du brauchst',
        'features.desc': 'Leistungsstarke Funktionen in einem schlanken Paket. Kein Ballast, kein Abo — nur dein API-Schlüssel.',
        'howitworks.label': 'Workflow',
        'howitworks.title': 'So funktioniert\'s',
        'howitworks.desc': 'Vier Schritte. Null Aufwand.',
        'privacy.label': 'Sicherheit',
        'privacy.title': 'Privatsphäre zuerst',
        'privacy.desc': 'Deine Daten bleiben bei dir. Immer.',
        'support.title': 'Projekt unterstützen',
        'support.desc': 'WhisPaste ist kostenlos und Open Source. Wenn es dir nützlich ist, unterstütze gerne die Entwicklung.',
        'support.sponsor': 'Auf GitHub sponsern',
        'support.coffee': 'Einen Kaffee ausgeben',
        'footer.impressum': 'Impressum',
        'footer.privacy': 'Datenschutz',
        'footer.license': 'MIT-Lizenz'
      }
    };

    let currentLang = localStorage.getItem('whispaste-lang') || 'en';

    function toggleLang() {
      currentLang = currentLang === 'en' ? 'de' : 'en';
      localStorage.setItem('whispaste-lang', currentLang);
      applyLang();
    }

    function applyLang() {
      document.documentElement.lang = currentLang;
      const btn = document.getElementById('langToggle');
      if (btn) btn.textContent = currentLang === 'en' ? 'DE' : 'EN';
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (i18n[currentLang]?.[key]) {
          el.textContent = i18n[currentLang][key];
        }
      });
    }

    // Theme toggle
    function toggleTheme() {
      const html = document.documentElement;
      const isDark = !html.classList.contains('light');
      if (isDark) {
        html.classList.add('light');
        localStorage.setItem('whispaste-theme', 'light');
      } else {
        html.classList.remove('light');
        localStorage.setItem('whispaste-theme', 'dark');
      }
      updateThemeIcon();
    }

    function updateThemeIcon() {
      const isLight = document.documentElement.classList.contains('light');
      const icon = document.getElementById('themeIcon');
      if (icon) {
        icon.innerHTML = isLight
          ? '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>'
          : '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
      }
      const lightSrc = '/whispaste/app-icon-light.png';
      const darkSrc = '/whispaste/app-icon-dark.png';
      const src = isLight ? lightSrc : darkSrc;
      ['navLogo', 'heroLogo', 'footerLogo'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.src = src;
      });
    }

    // Expose functions globally for onclick handlers
    window.toggleLang = toggleLang;
    window.toggleTheme = toggleTheme;

    // Apply on load
    applyLang();
    updateThemeIcon();
  </script>
</Layout>
