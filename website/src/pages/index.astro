      display: flex;
      align-items: center;
      font-family: 'Segoe UI', system-ui, sans-serif;
      transform: scale(0.85);
      transform-origin: center;
    }
    @media (min-width: 640px) {
      .overlay-pill { transform: scale(1); }
    }
    .overlay-icon {
      width: 36px;
      height: 36px;
      margin-left: 14px;
      border-radius: 4px;
    }
    .overlay-content {
      margin-left: 12px;
