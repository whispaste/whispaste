      background: #FF3C3C;
      animation: rec-pulse 1.2s ease-in-out infinite;
    }
    @keyframes rec-pulse {
      0%, 100% { opacity: 0.7; }
      50% { opacity: 1; }
    }
    .overlay-text-main {
      font-size: 15px;
      font-weight: 600;
      color: #FFFFFF;
      line-height: 1;
    }
    .overlay-text-timer {
      font-size: 11px;
