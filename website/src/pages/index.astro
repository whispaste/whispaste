      color: #90A0B0;
      line-height: 1;
    }
    .overlay-waveform {
      display: flex;
      align-items: center;
      gap: 3px;
      margin-left: auto;
      margin-right: 8px;
      height: 48px;
      flex-shrink: 0;
      min-width: 137px;
    }
    :global(.overlay-wave-bar) {
      width: 4px;
      border-radius: 2px;
      min-height: 2px;
      flex-shrink: 0;
    }
    .overlay-buttons {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-right: 12px;
    }
    .overlay-btn-pause, .overlay-btn-confirm {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .overlay-btn-pause svg, .overlay-btn-confirm svg {
      width: 34px;
      height: 34px;
    }
    .overlay-btn-pause { background: #0E7490; }
    .overlay-btn-confirm { background: #22D3EE; }

    /* Speaking head + microphone icon (Scene 2) */
    .speaking-head {
      color: rgba(255, 255, 255, 0.5);
    }
    .microphone-icon {
      color: rgba(255, 255, 255, 0.4);
      animation: mic-glow 1.8s ease-in-out infinite;
    }
    @keyframes mic-glow {
      0%, 100% { color: rgba(255, 255, 255, 0.4); }
      50% { color: #22D3EE; }
    }
    .speaking-head-icon .sound-arc {
      opacity: 0;
      stroke: #22D3EE;
    }
    .sound-arc.arc-1 { animation: sound-pulse 1.8s ease-in-out infinite; }
    .sound-arc.arc-2 { animation: sound-pulse 1.8s ease-in-out 0.3s infinite; }
    @keyframes sound-pulse {
      0%, 100% { opacity: 0; }
      30%, 70% { opacity: 0.7; }
    }

    /* Typing cursor (Scene 3) — :global because JS recreates it */
    :global(.typing-cursor) {
      display: inline-block;
      width: 2px;
      height: 1.1em;
      background: #22D3EE;
      margin-left: 1px;
      animation: cursor-blink 0.8s step-end infinite;
      vertical-align: text-bottom;
    }
    :global(.carousel-heart) {
      color: #EF4444;
    }
    @keyframes cursor-blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

